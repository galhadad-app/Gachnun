<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>הגחנון של חדד</title>

<style>
body {
    font-family: Arial, sans-serif;
    background: #f8f8f8;
    margin: 0;
}

.container {
    max-width: 400px;
    margin: auto;
    padding: 20px;
    text-align: center;
}

.logo {
    width: 120px;
    border-radius: 50%;
}

h1 {
    margin: 10px 0;
}

.menu {
    background: white;
    padding: 15px;
    border-radius: 15px;
    margin-top: 15px;
    text-align: right;
}

.item {
    margin: 10px 0;
}

button {
    width: 100%;
    padding: 12px;
    margin-top: 10px;
    border: none;
    border-radius: 10px;
    font-size: 16px;
    cursor: pointer;
}

.order-btn {
    background: #f4a300;
    color: white;
}

.whatsapp-btn {
    background: #25D366;
    color: white;
}

input {
    width: 100%;
    padding: 10px;
    margin: 5px 0;
    border-radius: 8px;
    border: 1px solid #ccc;
}

.notice {
    color: red;
    font-size: 14px;
    margin-top: 10px;
}
</style>
</head>

<body>

<div class="container">

    <!-- לוגו -->
    <img src="logo.png" class="logo">

    <h1>הגחנון של חדד</h1>

    <!-- תפריט -->
    <div class="menu">
        <h3>תפריט</h3>

        <div class="item">
            <label>
                <input type="checkbox" value="גחנון (4 יח') - 50₪">
                גחנון (4 יחידות) - 50₪
            </label>
        </div>

        <div class="item">
            <label>
                <input type="checkbox" value="קובנה (3 יח') - 20₪">
                קובנה (שלישיה) - 20₪
            </label>
        </div>

        <div class="item">
            <label>
                <input type="checkbox" value="חריף - 10₪">
                חריף - 10₪
            </label>
        </div>

        <div class="item">
            <label>
                <input type="checkbox" id="delivery">
                משלוח (+5₪)
            </label>
        </div>
    </div>

    <!-- פרטים -->
    <div class="menu">
        <h3>פרטי הזמנה</h3>

        <input type="text" id="name" placeholder="שם">
        <input type="tel" id="phone" placeholder="מספר פלאפון">
    </div>

    <div class="notice">
        הזמנות עד יום שלישי בשעה 22:00
    </div>

    <!-- כפתורים -->
    <button class="order-btn" onclick="sendOrder()">בצע הזמנה</button>

    <button class="whatsapp-btn" onclick="openWhatsapp()">מעבר לווצאפ</button>

</div>

<script>
function sendOrder() {
    let name = document.getElementById("name").value;
    let phone = document.getElementById("phone").value;

    let items = [];
    document.querySelectorAll('input[type="checkbox"]:checked').forEach(cb => {
        if (cb.id !== "delivery") {
            items.push(cb.value);
        }
    });

    let delivery = document.getElementById("delivery").checked ? "משלוח (+5₪)" : "איסוף עצמי";

    if (!name || !phone || items.length === 0) {
        alert("נא למלא את כל הפרטים ולבחור מוצרים");
        return;
    }

    let message = `הזמנה חדשה:%0Aשם: ${name}%0Aטלפון: ${phone}%0Aפריטים:%0A- ${items.join("%0A- ")}%0A${delivery}`;

    window.open(`https://wa.me/972523971954?text=${message}`, '_blank');
}

function openWhatsapp() {
    window.open("https://wa.me/972523971954", '_blank');
}
</script>

</body>
</html>
